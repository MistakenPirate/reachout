    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@repo/shared": "workspace:^",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.8",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.3",
    "typescript": "5.9.2"
